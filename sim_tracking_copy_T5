def run_scenario_B():
    # Radar-only
    xB, gtB, innovB, SB, radar, camera = sim_tracking(
        "harbour_sim_output/scenario_B.json", scenario="B", mode="radar")
    nisB, dofB = compute_nis(innovB, SB)
    rmseB = compute_rmse(xB, gtB)
    plot_nis(nisB, dofB, "Scenario B - Radar-only")

    # Sequential
    xB_seq, gtB, innovB_seq, SB_seq, radar, camera = sim_tracking(
        "harbour_sim_output/scenario_B.json", scenario="B", mode="sequential")
    nisB_seq, dofB_seq = compute_nis(innovB_seq, SB_seq)
    rmseB_seq = compute_rmse(xB_seq, gtB)
    plot_nis(nisB_seq, dofB_seq, "Scenario B - Sequential Fusion")

    # Joint
    xB_joint, gtB, innovB_j, SB_j, radar, camera = sim_tracking(
        "harbour_sim_output/scenario_B.json", scenario="B", mode="joint")
    nisB_j, dofB_j = compute_nis(innovB_j, SB_j)
    rmseB_j = compute_rmse(xB_joint, gtB)
    plot_nis(nisB_j, dofB_j, "Scenario B - Joint Fusion")

    # Trajectories
    plot_trajectories(gtB, [xB],      ["Radar-only"],       measurements=[(radar, "Radar")])
    plot_trajectories(gtB, [xB_seq],  ["Sequential Fusion"], measurements=[(radar, "Radar"), (camera, "Camera")])
    plot_trajectories(gtB, [xB_joint],["Joint Fusion"],      measurements=[(radar, "Radar"), (camera, "Camera")])

    # Summary comparison
    plot_rmse_bar(
        [np.linalg.norm(rmseB), np.linalg.norm(rmseB_seq), np.linalg.norm(rmseB_j)],
        ["Radar-only", "Sequential", "Joint"]
    )

    return {
        "radar":      (xB,      rmseB,     nisB),
        "sequential": (xB_seq,  rmseB_seq, nisB_seq),
        "joint":      (xB_joint,rmseB_j,   nisB_j),
