# MAIN SIMULATION FUNCTION

def sim_tracking(json_file, scenario="A", mode="radar"):

    data = json.load(open(json_file, "r", encoding="utf-8"))

    gt_times, gt_states = extract_ground_truth(data)

    print(f"Simulating Scenario {scenario} with mode {mode}")

    match scenario:

        case "A":
            meas = [
                (m["time"], m["range_m"], m["bearing_rad"])
                for m in data["measurements"]
                if m["sensor_id"] == "radar" and not m["is_false_alarm"]
            ]

            meas = np.array(meas)
            ts = meas[:, 0]
            zs_radar = meas[:, 1:]

            x_est, innov_hist, S_hist = run_ekf_radar_only(ts, zs_radar, x0 = np.array([800, 600, -1, -2]))

            gt_interp = interpolate_gt(gt_times, gt_states, ts)

            return x_est, gt_interp, innov_hist, S_hist, meas

        case "B":
            radar = [
                (m["time"], m["range_m"], m["bearing_rad"])
                for m in data["measurements"]
                if m["sensor_id"] == "radar" and not m["is_false_alarm"]
            ]

            camera = [
                (m["time"], m["range_m"], m["bearing_rad"])
                for m in data["measurements"]
                if m["sensor_id"] == "camera" and not m["is_false_alarm"]
            ]

            radar = np.array(radar)
            camera = np.array(camera)

            ts_radar = radar[:, 0]
            zs_radar = radar[:, 1:]

            ts_camera = camera[:, 0]
            zs_camera = camera[:, 1:]

            # print("ts_radar:", ts_radar)
            # print("ts_camera:", ts_camera)

            if mode == "joint":
                x_est, innov_hist, S_hist = run_ekf_joint(ts_radar, ts_camera, zs_radar, zs_camera, x0 = np.array([400, 80, 1.2, 2.2]))
                gt_interp = interpolate_gt(gt_times, gt_states, ts_radar)
            elif mode == 'radar':
                x_est, innov_hist, S_hist = run_ekf_radar_only(ts_radar, zs_radar, x0 = np.array([400, 80, 1.2, 2.2]))
                gt_interp = interpolate_gt(gt_times, gt_states, ts_radar)
            else: # sequential
                x_est, ts_est, innov_hist, S_hist = run_ekf_sequential(ts_radar, ts_camera, zs_radar, zs_camera, x0 = np.array([400, 80, 1.2, 2.2]))
                gt_interp = interpolate_gt(gt_times, gt_states, ts_est)
            
            return x_est, gt_interp, innov_hist, S_hist, radar, camera

        case "C":
            # Collect measurements by sensor
            radar = [
                (m["time"], m["range_m"], m["bearing_rad"])
                for m in data["measurements"]
                if m["sensor_id"] == "radar" and not m["is_false_alarm"]
            ]

            camera = [
                (m["time"], m["range_m"], m["bearing_rad"])
                for m in data["measurements"]
                if m["sensor_id"] == "camera" and not m["is_false_alarm"]
            ]

            ais = [
                (m["time"], m["north_m"], m["east_m"])
                for m in data["measurements"]
                if m["sensor_id"] == "ais" and not m["is_false_alarm"]
            ]

            gnss = [
                (m["time"], m["north_m"], m["east_m"], m.get("target_id", -1))
                for m in data["measurements"]
                if m["sensor_id"] == "gnss" and not m["is_false_alarm"]
            ]

            radar = np.array(radar)
            camera = np.array(camera)
            ais = np.array(ais)
            gnss = np.array(gnss)

            ts_radar = radar[:, 0] if len(radar) > 0 else np.array([])
            zs_radar = radar[:, 1:] if len(radar) > 0 else np.array([])

            ts_camera = camera[:, 0] if len(camera) > 0 else np.array([])
            zs_camera = camera[:, 1:] if len(camera) > 0 else np.array([])

            ts_ais = ais[:, 0] if len(ais) > 0 else np.array([])
            zs_ais = ais[:, 1:] if len(ais) > 0 else np.array([])

            ts_gnss = gnss[:, 0] if len(gnss) > 0 else np.array([])
            zs_gnss = gnss[:, 1:4] if len(gnss) > 0 else np.array([])

            if mode == "radar":
                x_est, innov_hist, S_hist = run_ekf_radar_only(ts_radar, zs_radar, x0 = np.array([650, 450, -2.5, -1.0]))
                gt_interp = interpolate_gt(gt_times, gt_states, ts_radar)
                meas = radar
            else:
                # sequential fusion of all sensors
                x_est, ts_est, innov_hist, S_hist = run_ekf_ais_gnss_seq(
                    ts_radar, ts_camera, ts_ais, ts_gnss,
                    zs_radar, zs_camera, zs_ais, zs_gnss,
                    x0 = np.array([650, 450, -2.5, -1.0])
                )
                gt_interp = interpolate_gt(gt_times, gt_states, ts_est)

            return x_est, gt_interp, innov_hist, S_hist, radar, camera, ais, gnss

    compute_rmse(x_est, gt_interp)

    return x_est, gt_interp, innov_hist, S_hist


# PLOTTING

def plot_trajectories(gt, results, labels, measurements=None):
    plt.figure(figsize=(8, 6))
    # plot with East on x-axis and North on y-axis
    plt.plot(gt[:, 1], gt[:, 0], 'k--', linewidth=2, label="Ground Truth")

    for x_est, label in zip(results, labels):
        plt.plot(x_est[:, 1], x_est[:, 0], linewidth=1.5, label=label)

    sensor_origins = {
        "Radar":  np.array([0.0,   0.0]),
        "Camera": np.array([-80.0, 120.0]),
    }

    if measurements is not None:
        if isinstance(measurements, list):
            for meas, meas_label in measurements:
                # Ensure numpy array
                meas_arr = np.asarray(meas)
                if meas_label in ["Radar", "Camera"]:
                    origin = sensor_origins.get(meas_label, np.array([0.0, 0.0]))
                    r, phi = meas_arr[:, 1].astype(float), meas_arr[:, 2].astype(float)
                    mN = origin[0] + r * np.cos(phi)
                    mE = origin[1] + r * np.sin(phi)
                    # scatter with East on x-axis, North on y-axis
                    plt.scatter(mE, mN, alpha=0.5, s=20, label=meas_label)
                elif meas_label == "GNSS":
                    # GNSS: column layout [time, north, east, ...]
                    mN = meas_arr[:, 1].astype(float)
                    mE = meas_arr[:, 2].astype(float)
                    plt.scatter(mE, mN, alpha=0.8, s=30, label=meas_label, marker='x')
                else:
                    # AIS or other Cartesian sensors: [time, north, east]
                    mN = meas_arr[:, 1].astype(float)
                    mE = meas_arr[:, 2].astype(float)
                    plt.scatter(mE, mN, alpha=0.6, s=20, label=meas_label, marker='o')
        else:
            r, phi = measurements[:, 1], measurements[:, 2]
            mN = r * np.cos(phi)
            mE = r * np.sin(phi)
            plt.scatter(mE, mN, alpha=0.5, s=20, label="Measurements")

    plt.xlabel("East (m)")
    plt.ylabel("North (m)")
    plt.title("Target Tracking Comparison (East vs North)")
    plt.legend()
    plt.axis("equal")
    plt.grid(True)
    plt.tight_layout()
    plt.show()

def plot_position_error(gt, x_est_list, labels):

    plt.figure(figsize=(8, 5))

    # Support either a single gt array or a list of gt arrays matching x_est_list
    if isinstance(gt, (list, tuple)) and len(gt) == len(x_est_list):
        for x_est, g, label in zip(x_est_list, gt, labels):
            if x_est.shape[0] != g.shape[0]:
                raise ValueError("GT and estimate lengths differ for a series; provide matching GT arrays or interpolate before plotting.")
            err = np.linalg.norm(x_est[:, :2] - g[:, :2], axis=1)
            plt.plot(err, label=label)
    else:
        for x_est, label in zip(x_est_list, labels):
            if x_est.shape[0] != gt.shape[0]:
                raise ValueError("GT and estimate lengths differ; provide matching GT array or interpolate before plotting.")
            err = np.linalg.norm(x_est[:, :2] - gt[:, :2], axis=1)
            plt.plot(err, label=label)

    plt.xlabel("Time step")
    plt.ylabel("Position error (m)")
    plt.title("Tracking Error Over Time")
    plt.legend()
    plt.grid(True)
    plt.tight_layout()
    plt.show()

def plot_nis(nis, dof, label):
    """Plot NIS with chi2 bounds. `dof` can be an int or an array per-sample.

    If `dof` is an array, the function will plot constant bounds using the
    most common dof value and will also annotate varying dof if present.
    """
    # Determine a representative degree of freedom
    if isinstance(dof, (list, tuple, np.ndarray)):
        dof = np.asarray(dof)
        # use the most common dof value for bounds
        rep_dof = int(np.bincount(dof).argmax())
    else:
        rep_dof = int(dof)

    lower = chi2.ppf(0.025, df=rep_dof)
    upper = chi2.ppf(0.975, df=rep_dof)

    plt.figure(figsize=(8, 4))
    plt.plot(nis, label="NIS")
    plt.axhline(lower, linestyle="--", color="red", label="95% bounds")
    plt.axhline(upper, linestyle="--", color="red")

    plt.xlabel("Time step")
    plt.ylabel("NIS")
    plt.title(f"NIS Consistency: {label} (dof={rep_dof})")
    plt.legend()
    plt.grid(True)
    plt.tight_layout()
    plt.show()

def plot_rmse_bar(rmse_values, labels):

    plt.figure(figsize=(6, 4))

    plt.bar(labels, rmse_values)

    plt.ylabel("RMSE (m)")
    plt.title("Position RMSE Comparison")
    plt.grid(True, axis="y")
    plt.tight_layout()
    plt.show()


